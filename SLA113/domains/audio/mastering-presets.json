{
  "domain": "audio",
  "version": "1.0",
  "description": "Mastering presets per genre. EQ curves, compression, limiting, and normalization targets used by the Soulfire Mastering engine and audio rendering pipeline.",
  "presets": [
    {
      "id": "chicano-soul-master",
      "name": "Chicano Soul",
      "genres": ["chicano-soul", "soul", "r-and-b"],
      "target": {"lufs": -14, "true_peak": -1.5, "bit_depth": 16, "sample_rate": 44100},
      "eq": {
        "sub_low": "highpass 30Hz gentle slope",
        "low": "boost +2dB shelf 80Hz",
        "low_mid": "cut -1.5dB 250Hz",
        "mid": "cut -1dB 800Hz",
        "high_mid": "boost +2dB 3kHz",
        "high": "gentle shelf -2dB 10kHz"
      },
      "compression": {
        "type": "opto",
        "ratio": 2.5,
        "threshold": -18,
        "attack": 10,
        "release": 150,
        "makeup": 3
      },
      "limiter": {"ceiling": -1.5, "release": "automatic"},
      "stereo_enhancement": {"width": "120%", "mid_side_eq": "side boost +1.5dB 5kHz"},
      "dither": "triangular"
    },
    {
      "id": "trap-master",
      "name": "Trap / Drill",
      "genres": ["trap-soul", "drill", "trap", "phonk", "latin-trap"],
      "target": {"lufs": -9, "true_peak": -1.0, "bit_depth": 16, "sample_rate": 44100},
      "eq": {
        "sub_low": "boost +4dB 40Hz",
        "low": "boost +2dB 80Hz",
        "low_mid": "cut -3dB 300Hz",
        "mid": "cut -2dB 500Hz",
        "high_mid": "boost +3dB 3kHz",
        "high": "boost +2dB shelf 8kHz"
      },
      "compression": {
        "type": "FET",
        "ratio": 6,
        "threshold": -22,
        "attack": 1,
        "release": 80,
        "makeup": 5
      },
      "limiter": {"ceiling": -1.0, "release": "medium"},
      "stereo_enhancement": {"width": "130%", "mid_side_eq": "side boost +2dB 10kHz"},
      "dither": "none"
    },
    {
